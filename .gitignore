# ---- VS Code extension (Node/TypeScript) ----

# Node dependencies
node_modules/

# Build output (TypeScript / bundlers)
out/
dist/
build/
*.tsbuildinfo

# Bundler caches (optional but common)
.esbuild/
.vite/
.parcel-cache/
.cache/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage / test artifacts
coverage/
.nyc_output/
.vscode-test/

# VS Code packaging output
*.vsix

# Environment / local config
.env
.env.*
!.env.example

# OS / editor junk
.DS_Store
Thumbs.db

# VS Code local settings (keep launch/tasks if you want)
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/extensions.json

# ---- Java language server side (if you include one in the repo) ----
# Maven
target/

# Gradle
.gradle/
**/build/

# IntelliJ / Eclipse
.idea/
*.iml
.classpath
.project
.settings/

# Java bytecode
*.class

# Generated JDT bundle
bundles/*.jar
